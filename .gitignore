# Node / Vite / Convex
node_modules/
dist/
.convex/
*.tsbuildinfo

# Local tool outputs (knowledge graph / image gen) — contain absolute local
# paths, never source; regenerated on demand. Never ship in the public repo.
nanobanana-output/
graphify-out/

# Local configuration and secrets — never commit
.env
.env.*
!.env.example
*.local.json
config.local.json
secrets/

# Runtime config: written by the static-server image (prod) or dropped locally;
# never committed. The bundle reads it at boot (src/lib/runtimeConfig.ts), with a
# VITE_CONVEX_URL fallback for local dev.
public/config.json

# NOTE: convex/_generated/ is COMMITTED on purpose (Convex convention) so the
# repo typechecks on a fresh clone before the first `convex dev`.

# i18n: Paraglide-generated message functions. Regenerated by `paraglide-js
# compile` (prepended to typecheck/test/build). The compiler also drops its own
# .gitignore inside, but we ignore the whole dir at the root for CI clarity.
src/paraglide/

# OpenClaw diagnostics
openclaw-frame-captures/
*.ndjson
*.log

# Ephemeral local artifacts (live-test screenshots, scratch outputs). Durable
# evidence belongs in openclaw-notes/docs/webchat/, never in this public repo.
.local/

# OS / editors
.DS_Store
.idea/
.vscode/

# Agent / IDE tooling — NOT shipped in the community repo. `.agents/` and
# `.claude/skills/*` are `convex ai-files install` artifacts: installable on
# demand, and the `.claude` ones are machine-local symlinks that dangle on a
# fresh clone. `.claude/worktrees/` are disposable workflow checkouts. None are
# source — a community clone installs its own via `npx convex ai-files install`.
.agents/
.claude/
