# Atrium — deployment configuration. Copy to `.env` and fill in.
# NEVER commit `.env`. There are TWO scopes (this is the #1 gotcha):
#
#   [A] CONTAINER env — read directly by the containers (docker-compose injects
#       these). Everything in section A below.
#   [B] CONVEX DEPLOYMENT env — read by Convex FUNCTIONS via process.env. These
#       are NOT injected by docker-compose; `bootstrap-env.sh` pushes them into
#       the deployment with `convex env set`. Section B below.
#
# Run order: fill this file -> `docker compose up -d` -> `./bootstrap-env.sh`.

# ============================================================================
# [A] CONTAINER env
# ============================================================================

# --- naming / images / ports ---
COMPOSE_PROJECT_NAME=atrium
# Where the two images live. CI (build-and-push.yml) publishes both to GHCR:
#   ghcr.io/lacneu/atrium  and  ghcr.io/lacneu/atrium-bridge
# A fork repoints these at its own owner. Lockstep-versioned: same tag for both.
WEBCHAT_IMAGE=ghcr.io/lacneu/atrium
WEBCHAT_TAG=latest
BRIDGE_IMAGE=ghcr.io/lacneu/atrium-bridge
BRIDGE_TAG=latest
WEBCHAT_PORT=8788
BRIDGE_PORT=8787
CONVEX_CLOUD_PORT=3210
CONVEX_SITE_PORT=3211
CONVEX_DASHBOARD_BIND=127.0.0.1
CONVEX_DASHBOARD_PORT=6791

# --- Convex backend (self-hosted) ---
CONVEX_INSTANCE_NAME=atrium
# Generate a strong random secret and BACK IT UP — it mints the admin keys.
#   openssl rand -hex 32
CONVEX_INSTANCE_SECRET=
# PUBLIC https origins the BROWSER reaches (via your reverse proxy / ingress).
CONVEX_CLOUD_ORIGIN=https://convex.example.com
CONVEX_SITE_ORIGIN=https://convex-site.example.com
CONVEX_RUST_LOG=info

# --- bridge -> your OpenClaw gateway (external to this stack) ---
OPENCLAW_GATEWAY_URL=wss://gateway.example.com
# The gateway operator token + Ed25519 device identity have TWO sources (pick one
# per credential — the bridge resolves each at boot, Convex-first then env):
#   [env mode, the default below] put the values here.
#   [UI mode] store them ENCRYPTED in Convex via Settings -> Agents -> Instances ->
#     Credentials, then set BRIDGE_INSTANCE_SECRET (below) and LEAVE THESE BLANK.
#     Requires ATRIUM_SECRET_KEY on the Convex deployment (section B). See the
#     "UI-managed gateway credentials" walkthrough in deploy/README.md.
# Rotating a UI-stored credential takes effect on the next bridge restart.
OPENCLAW_TOKEN=
# Ed25519 device identity JSON: {"id":"...","publicKey":"...","privateKey":"<PEM PKCS#8>"}
OPENCLAW_DEVICE_IDENTITY=
# [UI mode only] Per-bridge secret that authenticates THIS bridge to Convex and
# binds it to its instance, so it can fetch ONLY this gateway's encrypted creds.
# MINT it in Settings -> Agents -> Instances -> Credentials ("Secret du bridge") —
# it is shown ONCE; paste it here. NOT the shared BRIDGE_INGEST_SECRET. Leave blank
# in env mode (then OPENCLAW_TOKEN/OPENCLAW_DEVICE_IDENTITY above must be set).
BRIDGE_INSTANCE_SECRET=
# The instance name THIS bridge serves (must match a Convex `instances.name`).
# ALSO keys the bridge's shared-fs media subdir: the bridge reads/writes
# /home/node/.openclaw/media/<this>/{outbound,inbound} (see below).
OPENCLAW_INSTANCE_NAME=primary
OPENCLAW_MEDIA_MAX_MB=1024

# --- shared-fs media (OPTIONAL — only if Atrium shares a filesystem with the
#     gateway; leave commented for the default gateway-http mode) -------------
# Deterministic file delivery (out) + big-file ingestion (in) need the bridge and
# the gateway to SHARE the gateway's media dirs on disk. Full guide + a worked
# 2-gateway example: deploy/SHARED_FS_MEDIA.md. The 4-path model in one line:
#   - the AGENT writes/reads the FLAT gateway path /home/node/.openclaw/media/{outbound,inbound}
#   - the BRIDGE reads/writes /home/node/.openclaw/media/<instance>/{outbound,inbound}
#     (auto-derived from OPENCLAW_INSTANCE_NAME — no env needed)
#   - BOTH bind the SAME host dirs below.
# HOST paths = where THIS instance's gateway keeps its media (its `.openclaw`
# mount): <root>/instances/<OPENCLAW_INSTANCE_NAME>/.openclaw/media/{outbound,inbound}.
#OPENCLAW_MEDIA_OUTBOUND_HOST_DIR=/path/to/instances/primary/.openclaw/media/outbound
#OPENCLAW_INBOUND_HOST_DIR=/path/to/instances/primary/.openclaw/media/inbound
# Match the uid:gid the gateway container runs as (else inbound files the bridge
# writes are unreadable by the agent). Uncomment `user:` + `volumes:` in
# docker-compose.yml to activate, then recreate the bridge.
#BRIDGE_RUN_AS_UID=1000:1000
# [gateway-http mode] Override the media HTTP base ONLY if the gateway serves the
# assistant-media endpoint on a different host/port than OPENCLAW_GATEWAY_URL.
# Leave blank to derive it (ws->http, wss->https, SAME host:port).
OPENCLAW_GATEWAY_HTTP_URL=
# [gateway-http mode] Connection timeout (ms): bounds the media meta-probe +
# response headers so a non-responsive gateway can't stall a turn (the body then
# streams at the upload's pace). Default 60000.
OPENCLAW_MEDIA_FETCH_TIMEOUT_MS=60000

# --- shared bridge<->Convex secrets (same value used in BOTH scopes) ---
#   openssl rand -hex 32   (one for each)
BRIDGE_INGEST_SECRET=
BRIDGE_SHARED_SECRET=

# ============================================================================
# [B] CONVEX DEPLOYMENT env  (pushed by bootstrap-env.sh via `convex env set`)
# ============================================================================

# Authoritative sign-in gate — set BEFORE anyone signs in. Comma-separated
# allowed email domains; the FIRST sign-in from an allowed domain becomes admin.
AUTH_ALLOWED_EMAIL_DOMAINS=example.com

# Google OAuth (https://console.cloud.google.com -> OAuth client).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Microsoft Entra OAuth (optional; leave blank to disable). These are the names
# @auth/core's microsoft-entra-id provider + convex/auth.ts actually read — the
# ISSUER is the AUTHORITATIVE tenant gate (a bare tenant id is NOT accepted; it
# must be the full issuer URL, else Microsoft stays disabled).
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Full issuer URL — NOT a bare tenant id. Substitute your tenant GUID/domain:
#   https://login.microsoftonline.com/<tenant-id>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# @convex-dev/auth signing keys — a MATCHING pair (the JWKS is the public half of
# the PEM; generate them TOGETHER or sign-in fails). The values are MULTILINE, so
# they are supplied as FILE PATHS, never inline: a dotenv line / Docker Compose
# can't hold a multiline PEM, and pasting one inline is the #1 cause of the
# `"pkcs8" must be PKCS#8 formatted string` sign-in error.
#
# Generate both files (no dependencies, writes the two paths below):
#     node generate-auth-keys.mjs
#
# Expected content:
#   - jwt_private_key.pem : a PKCS#8 PEM, `-----BEGIN PRIVATE KEY-----` … END,
#                           with REAL newlines (the private signing key).
#   - jwks.json           : `{"keys":[{"use":"sig","kty":"RSA","n":"…","e":"…"}]}`
#                           (the public half — what verifies the tokens).
# Paths are relative to THIS .env, so they stay portable across hosts.
# bootstrap-env.sh reads each `<KEY>_FILE` verbatim and pushes it via `convex env set`.
JWT_PRIVATE_KEY_FILE=jwt_private_key.pem
JWKS_FILE=jwks.json
# Public site URL (OAuth callbacks). Usually the frontend's public origin.
SITE_URL=https://webchat.example.com

# Master key that encrypts GATEWAY CREDENTIALS at rest in Convex (the token,
# Ed25519 device identity and Hermes API key entered in Settings → Agents →
# Instances → Credentials land in the `instanceSecrets` table AES-256-GCM-
# encrypted, never as plaintext). Base64 of 32 random bytes. Same model as n8n's
# N8N_ENCRYPTION_KEY: keep it in env (here / a Helm Secret / your vault), NEVER in
# the DB. Treat it as a ROOT secret + BACK IT UP — losing or changing it makes
# existing encrypted credentials unrecoverable (you'd re-enter them in the UI).
# Leave blank if you don't store gateway credentials in the UI (the feature stays
# inert; the bridge keeps using its env). Generate one:
#   - Linux / macOS:    openssl rand -base64 32
#   - Windows / any OS:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ATRIUM_SECRET_KEY=

# bridge wiring (Convex-scoped). SERVICE-NAME URLs work inside the compose net.
BRIDGE_URL=http://bridge:8787
BRIDGE_INSTANCE_NAME=primary

# Optional trace shipping (leave blank to disable). Keys live in Convex env.
# Langfuse host var is LANGFUSE_HOST (what convex/integrations/config.ts reads);
# leave blank for the cloud default (https://cloud.langfuse.com).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
OPIK_API_KEY=
OPIK_WORKSPACE=
OPIK_BASE_URL=
# Opik project ATRIUM's OWN traces ship to + are read back from (the read API
# requires it). Blank = "Default Project".
OPIK_PROJECT_NAME=
# SEPARATE project Atrium READS OpenClaw's own traces from (the plugins ship there,
# e.g. openclaw-<canonical>). Blank = no OpenClaw thread-search (enrichment then
# surfaces only Atrium's own traces). Enables seeing the REAL OpenClaw span tree.
OPIK_OPENCLAW_PROJECT=
