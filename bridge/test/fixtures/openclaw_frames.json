        {"event": "agent", "payload": {"sessionKey": "agent:main:webchat:chat:u-testuser01:own-chat", "runId": "run-own", "stream": "assistant", "data": {"text": "Réponse arrivée après final vide."}}},
        {"event": "chat", "payload": {"sessionKey": "agent:main:webchat:chat:u-testuser01:own-chat", "runId": "run-own", "state": "final", "seq": 2, "message": {"role": "assistant", "content": [{"type": "text", "text": "Réponse arrivée après final vide."}]}}}
      ]
    },
    "duplicate-final": {
