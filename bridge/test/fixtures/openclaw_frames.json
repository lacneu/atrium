        {"event": "chat", "payload": {"sessionKey": "agent:main:webchat:chat:u-testuser01:own-chat", "runId": "run-own", "seq": 1, "state": "delta", "message": {"role": "assistant", "content": [{"type": "text", "text": "Bon"}]}}},
        {"event": "chat", "payload": {"sessionKey": "agent:main:webchat:chat:u-testuser01:own-chat", "runId": "run-own", "seq": 2, "state": "final", "message": {"role": "assistant", "content": [{"type": "text", "text": "Bonjour !"}]}}}
      ]
    },
    "chat-final-content-string": {
