# Bridge worker environment. Copy to .env and fill in. EVERY secret here lives
# ONLY in the bridge process — never in a Convex table or the browser.
# The process fails fast at startup if a REQUIRED var is missing.

# --- OpenClaw Gateway --------------------------------------------------------
# Gateway URL. Accepts ws:// wss:// http:// https:// (http/https are rewritten
# to ws/wss). REQUIRED.
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:8765

# Bearer token sent in the connect request's auth.token. REQUIRED.
OPENCLAW_TOKEN=

# Ed25519 device identity as inline JSON: {"id":"...","publicKey":"...","privateKey":"<PEM PKCS#8>"}
# The privateKey is a PEM-encoded PKCS#8 Ed25519 key. REQUIRED.
# (Newlines in the PEM must be escaped as \n inside the JSON string.)
OPENCLAW_DEVICE_IDENTITY={"id":"device-1","publicKey":"...","privateKey":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}

# The instance NAME this bridge serves. OPTIONAL but RECOMMENDED. When set, the
# bridge refuses any /send|/patch|/reset whose body claims a DIFFERENT instance
# (M2 guard — a Convex routing misconfig fails loudly instead of answering from
# the wrong gateway). It MUST equal, three ways:
#   this OPENCLAW_INSTANCE_NAME  ==  Convex `instances.name` (the row mapping to
#   this bridge's BRIDGE_URL)  ==  Convex env BRIDGE_INSTANCE_NAME (the poller).
# The gateway session key is now `agent:<agentId>:webchat:chat:<canonical>:<chatId>`
# where agentId + canonical are ROUTED PER-TURN from the request body (Convex
# resolves the discovered agent + per-user canonical). There is intentionally NO
# OPENCLAW_AGENT_ID / OPENCLAW_CANONICAL env any more: sourcing the agent id from
# a static env was the root cause of the "Agent <env-id> no longer exists" bug.
OPENCLAW_INSTANCE_NAME=

# OPTIONAL configured gateway version (strict "YYYY.M.P", e.g. 2026.6.5). A
# FALLBACK the /capabilities endpoint uses ONLY when no live session and no
# discovery has supplied the real version yet — so a freshly-restarted, idle
# bridge still resolves the served instance's capabilities (Agent Files / Chat
# Defaults) instead of "version unknown". The REAL discovered/live version
# always wins (live > discovered > this). Set it to the gateway version this
# instance runs; a malformed value is ignored. Strongly recommended in prod so
# the version-gated UI works immediately after a bridge restart.
OPENCLAW_GATEWAY_VERSION=

# How the bridge fetches OUTBOUND (agent-generated) file bytes to upload into
# Convex storage. Optional; default = gateway-http.
#   gateway-http (DEFAULT) — fetch over HTTP from the gateway's
#       /__openclaw__/assistant-media endpoint. Needs NO shared filesystem, so it
#       works when Atrium and the gateway run on DIFFERENT hosts (the common case).
#   shared-fs              — read from a read-only mount of the gateway's
#       media/outbound dir (OPENCLAW_MEDIA_OUTBOUND_DIR below). OPT-IN: only when
#       Atrium and the gateway share a filesystem (same host / NFS).
#   off                    — never fetch outbound media (no attachment parts).
OPENCLAW_MEDIA_MODE=gateway-http

# [gateway-http mode] OPTIONAL override for the gateway's HTTP origin. By default
# the bridge derives it from OPENCLAW_GATEWAY_URL (ws->http, wss->https, same
# host:port — the endpoint is served on the WS port). Set this only when the
# gateway's HTTP server is on a different host/port than its WebSocket.
OPENCLAW_GATEWAY_HTTP_URL=

# [gateway-http mode] Connection timeout (ms): bounds the meta-probe + the download
# response HEADERS so a gateway that never responds can't hang a turn. The body then
# streams at the Convex upload's pace (not bounded — backpressure isn't a stall).
# Default 60000.
OPENCLAW_MEDIA_FETCH_TIMEOUT_MS=60000

# Session re-hydration kill-switch. On a fresh/rolled gateway session the bridge
# re-sends prior turns for context; it already SKIPS that on attachment turns (the
# gateway crashes assembling prepended history + an attachment). Set "off" to
# disable re-hydration entirely; anything else (default) keeps it on.
OPENCLAW_REHYDRATION=on

# [shared-fs mode ONLY] Directory the gateway writes outbound media into (the
# normalizer only ever surfaces paths under here). Optional; default shown.
OPENCLAW_MEDIA_OUTBOUND_DIR=/home/node/.openclaw/media/outbound

# --- Convex (bridge -> Convex ingest) ----------------------------------------
# Convex HTTP ACTIONS base URL — the `.site` origin, NOT the `.cloud` query
# origin. For local anonymous Convex this is the http-actions port (verify with
# `npx convex dev`). REQUIRED.
CONVEX_HTTP_ACTIONS_URL=http://127.0.0.1:3213

# Bearer secret the bridge presents to the Convex ingest httpAction. MUST equal
# the deployment env value: `npx convex env set BRIDGE_INGEST_SECRET <secret>`.
# REQUIRED.
BRIDGE_INGEST_SECRET=

# --- Inbound (Convex bridge.dispatch -> this bridge) -------------------------
# Secret Convex's bridge.dispatch presents to our POST /send (raw Authorization
# header, no "Bearer "). MUST equal the deployment env value:
# `npx convex env set BRIDGE_SHARED_SECRET <secret>`. REQUIRED.
BRIDGE_SHARED_SECRET=

# HTTP server port for POST /send + GET /health. Optional; default 8787.
BRIDGE_PORT=8787

# Max accepted request body size in bytes for POST /send. Optional; default 32 MiB.
# MUST exceed the base64-encoded attachment ceiling: Convex caps each inbound
# attachment at 20 MiB RAW, and base64 inflates by ~4/3 (~26.7 MiB on the wire)
# plus the JSON envelope. The old 1 MiB value 413'd every file import whose
# base64 topped ~1 MiB (~750 KiB raw) — leave unset to inherit the 32 MiB default,
# or raise further if you raise Convex's INBOUND_MAX_BYTES.
BRIDGE_MAX_BODY_BYTES=33554432
