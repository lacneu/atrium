# Convex DEPLOYMENT environment variables (set on the live deployment with
# `npx convex env set <KEY> <value>` — NEVER commit real values, NEVER store in
# tables, NEVER expose to the browser).
#
# Convex Auth (Google sign-in). @auth/core's Google provider reads these.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Convex -> Bridge dispatch (used by convex/bridge.ts).
# BRIDGE_URL: base URL Convex uses to reach the bridge's POST /send.
# BRIDGE_SHARED_SECRET: server-to-server auth header for that POST.
BRIDGE_URL=
BRIDGE_SHARED_SECRET=

# CONVEX_SITE_URL is provided automatically by the deployment (used by
# auth.config.ts). Do not set manually.
