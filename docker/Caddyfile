# Static SPA server for atrium. HTTP only — TLS + the public domain are
# handled upstream by Traefik (file-provider) on the NAS.
{
	admin off
	auto_https off
}

:80 {
	root * /srv
	encode gzip zstd

	# /config.json is written at boot by the entrypoint from $CONVEX_URL and read
	# by the SPA at boot (src/lib/runtimeConfig.ts). Never cache it so a redeploy
	# or env change is picked up immediately.
	@config path /config.json
	header @config Cache-Control "no-store"

	# Hashed build assets are immutable → cache hard.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# The SPA shell (index.html, served for every non-asset route via the fallback
	# below) must ALWAYS revalidate, so a new deploy is picked up without a manual
	# hard-refresh. Everything that isn't a hashed asset or /config.json = the shell.
	@html {
		not path /assets/*
		not path /config.json
	}
	header @html Cache-Control "no-cache"

	# SPA routing: serve real files first (so /config.json and /assets are NOT
	# shadowed), fall back to index.html for client-side routes.
	try_files {path} /index.html
	file_server
}
